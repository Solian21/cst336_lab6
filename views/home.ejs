<!DOCTYPE html>
<html lang="en">
<%- include('partials/head') %>
  <body>
    <div class="header">
      <h1> Quote Finder </h1>
    </div>
    
    <!--Search by Keyword -->
    <div>
      <form action="/searchByKeyword" method="GET">
        Keyword: <input type="text" name="keyword">
        <button> Search by Keyword </button>
      </form> <br><br>
    </div>

    <!-- Search by Author -->
    <form action="/searchByAuthor" method="GET">
      Author:
      <select name="authorId">
        <% for (let i of authors) {%>
          <option value=" <%= i.authorId %> ">
            <%= i.firstName %>
              <%= i.lastName %>
          </option>
          <% } %>
      </select>

      <button> Search by Authors </button>
    </form>

    <%- include('partials/footer') %>
  </body>

</html>